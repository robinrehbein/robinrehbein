{
  "name": "@robinrehbein/home",
  "version": "0.0.0",
  "exports": "./main.ts",
  "tasks": {
    "check": "deno fmt --check main.ts client.ts utils.ts vite.config.ts deno.json assets/styles.css routes components islands lib && deno lint main.ts client.ts utils.ts vite.config.ts routes components islands lib && deno check main.ts client.ts utils.ts vite.config.ts routes/**/*.ts routes/**/*.tsx components/**/*.tsx islands/**/*.tsx lib/**/*.ts",
    "dev": "deno run -A vite --host",
    "build": "deno run -A vite build",
    "start": "deno serve -A _fresh/server.js"
  },
  "lint": { "rules": { "tags": ["fresh", "recommended"] } },
  "exclude": ["**/_fresh/*", ".vite/**", ".kilocode/**", "node_modules/**"],
  "imports": {
    "fresh": "jsr:@fresh/core@^2.2.0",
    "fresh/": "jsr:@fresh/core@^2.2.0/",
    "fresh/runtime": "jsr:@fresh/core@^2.2.0/runtime",
    "fresh/runtime-client": "jsr:@fresh/core@^2.2.0/runtime-client",
    "fresh/internal": "jsr:@fresh/core@^2.2.0/internal",
    "occt-import-js": "npm:occt-import-js@^0.0.23",
    "preact": "npm:preact@^10.27.2",
    "preact/": "npm:preact@^10.27.2/",
    "preact/jsx-runtime": "npm:preact@^10.27.2/jsx-runtime",
    "preact/jsx-dev-runtime": "npm:preact@^10.27.2/jsx-dev-runtime",
    "preact/hooks": "npm:preact@^10.27.2/hooks",
    "@preact/signals": "npm:@preact/signals@^2.5.0",
    "@fresh/plugin-vite": "jsr:@fresh/plugin-vite@^1.0.8",
    "three": "npm:three@^0.181.2",
    "vite": "npm:vite@^7.1.3",
    "tailwindcss": "npm:tailwindcss@^4.1.10",
    "@tailwindcss/vite": "npm:@tailwindcss/vite@^4.1.12",
    "tailwind-merge": "npm:tailwind-merge@^2.6.1",
    "@nick/clsx": "jsr:@nick/clsx@^0.3.1",
    "class-variance-authority": "npm:class-variance-authority@^0.7.1",
    "gfm": "jsr:@deno/gfm@^0.10.0",
    "@std/path": "jsr:@std/path@^1.0.0",
    "@std/http/cookie": "jsr:@std/http@^1.0.0/cookie",
    "@std/assert": "jsr:@std/assert@^1.0.0",
    "@std/dotenv": "jsr:@std/dotenv@^0.225.6",
    "@std/http": "jsr:@std/http@^1.0.25",
    "@/": "./",
    "@std/": "jsr:@std/"
  },
  "compilerOptions": {
    "lib": [
      "deno.unstable",
      "dom",
      "dom.asynciterable",
      "dom.iterable",
      "deno.ns"
    ],
    "jsx": "precompile",
    "jsxImportSource": "preact",
    "jsxPrecompileSkipElements": [
      "a",
      "img",
      "source",
      "body",
      "html",
      "head",
      "title",
      "meta",
      "script",
      "link",
      "style",
      "base",
      "noscript",
      "template"
    ],
    "types": ["vite/client"]
  },
  "nodeModulesDir": "auto"
}
